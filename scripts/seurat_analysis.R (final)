library(Seurat)
library(dplyr)
library(ggplot2)
library(plotly)
library(htmlwidgets)

# BS7120 group assignment
# Reanalysis of GSE75140 with Seurat

counts <- read.table("GSE75140_hOrg.fetal.master.data.frame.txt",
                     header = TRUE,
                     row.names = 1)

# Build object
seurat_obj <- CreateSeuratObject(
  counts = counts,
  min.cells = 3,
  min.features = 200
)

# Quick QC
seurat_obj[["percent.mt"]] <- PercentageFeatureSet(
  seurat_obj,
  pattern = "^MT-"
)

# Kept this filter fairly broad so I didn't throw away too many cells early on
seurat_obj <- subset(
  seurat_obj,
  subset = nFeature_RNA > 500 & nFeature_RNA < 7000
)

# SCTransform + PCA 
seurat_obj <- SCTransform(seurat_obj, verbose = FALSE)
seurat_obj <- RunPCA(seurat_obj, verbose = FALSE)

# Clustering
seurat_obj <- FindNeighbors(seurat_obj, dims = 1:15)
seurat_obj <- FindClusters(seurat_obj, resolution = 0.5)

# 0.5 gave a cleaner split than lower settings without over-fragmenting the clusters
seurat_obj <- RunUMAP(seurat_obj, dims = 1:15)

p2d <- DimPlot(seurat_obj, reduction = "umap", label = TRUE)

ggsave("UMAP_2D_clusters.png",
       plot = p2d,
       width = 7,
       height = 6)

# 3D UMAP just to visualise cluster separation a bit differently
seurat_obj <- RunUMAP(seurat_obj,
                      dims = 1:15,
                      n.components = 3)

umap_3d <- Embeddings(seurat_obj, "umap")

plot3D <- plot_ly(
  x = umap_3d[,1],
  y = umap_3d[,2],
  z = umap_3d[,3],
  type = "scatter3d",
  mode = "markers",
  color = as.factor(Idents(seurat_obj)),
  marker = list(size = 3)
)

htmlwidgets::saveWidget(
  plot3D,
  "Final_UMAP_3D_resolution0.5.html"
)

# Marker detection
markers <- FindAllMarkers(
  seurat_obj,
  only.pos = TRUE,
  min.pct = 0.25,
  logfc.threshold = 0.25
)

top_markers <- markers %>%
  group_by(cluster) %>%
  slice_max(order_by = avg_log2FC, n = 10)

write.csv(top_markers,
          "Top10_markers_per_cluster.csv",
          row.names = FALSE)

# Assign simple condition labels from sample names 
seurat_obj$condition <- ifelse(
  grepl("hOrg", colnames(seurat_obj)),
  "Organoid",
  "Fetal"
)

cluster_condition_table <- table(
  Idents(seurat_obj),
  seurat_obj$condition
)

write.csv(cluster_condition_table,
          "Cluster_vs_Condition_table.csv")
